# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=mydb

# Backup
BACKUP_DIR=/backups
BACKUP_RETENTION=7

# Telegram (opcional — si no se configura, no notifica)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
NOTIFY_ON_SUCCESS=true
